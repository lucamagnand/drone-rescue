    "## Section 2 — Exercice guidé pas-à-pas\n",
    "\n",
    "### Étape 1 — Comprendre la garde `if __name__ == '__main__'`\n",
    "\n",
    "Teste ce comportement fondamental :"
   ]
  },
  {
   "cell_type": "code",
   "id": "test-name",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# Cellule 1 — Observer __name__\n",
    "# Dans un notebook, __name__ vaut '__main__' (comme si on exécutait directement)\n",
    "print('Valeur de __name__ dans ce notebook :', __name__)\n",
    "\n",
    "# Dans un fichier .py importé, __name__ vaut le nom du module (ex: 'main')\n",
    "# C'est pourquoi la garde 'if __name__ == __main__' protège l'exécution\n",
    "if __name__ == '__main__':\n",
    "    print('Ce code NE s\'exécute PAS si le fichier est importé.')\n",
    "    print('Il s\'exécute UNIQUEMENT si le fichier est lancé directement.')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "etape2",
   "metadata": {},
   "source": [
    "### Étape 2 — Simuler les modules du jeu (inline, sans import externe)\n",
    "\n",
    "Pour simuler l'assemblage sans avoir les fichiers du jeu, on crée des versions\n",
    "minimalistes de chaque fonction directement dans ce notebook."
   ]
  },
  {
   "cell_type": "code",
   "id": "simuler-modules",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# Cellule 2 — Versions simulées des fonctions du jeu\n",
    "import random\n",
    "\n",
    "def demarrer_log():\n",
    "    \"\"\"Démarre le logger (simulation : affiche un message).\"\"\"\n",
    "    print('[LOG] Partie démarrée.')\n",
    "\n",
    "def initialiser_partie():\n",
    "    \"\"\"Retourne un état minimal de test.\"\"\"\n",
    "    return {\n",
    "        'tour': 0,\n",
    "        'score': 0,\n",
    "        'partie_finie': False,\n",
    "        'victoire': False,\n",
    "        'drones': {'D1': {'id': 'D1', 'col': 0, 'lig': 0, 'batterie': 20, 'hors_service': False}},\n",
    "        'survivants': {},\n",
    "        'tours_max': 3,\n",
    "    }\n",
    "\n",
    "def render_grille(etat):\n",
    "    \"\"\"Affiche l'état courant (simulation).\"\"\"\n",
    "    print(f\"[GRILLE] Tour {etat['tour']} | Score {etat['score']}\")\n",
    "\n",
    "def boucle_de_jeu(etat):\n",
    "    \"\"\"Boucle principale simplifiée pour le test.\"\"\"\n",
    "    while not etat['partie_finie']:\n",
    "        etat['tour'] += 1\n",
    "        render_grille(etat)\n",
    "        if etat['tour'] >= etat['tours_max']:\n",
    "            etat['partie_finie'] = True\n",
    "            etat['victoire'] = len(etat['survivants']) == 0  # victoire si aucun survivant restant\n",
    "\n",
    "print('Modules simulés chargés avec succès.')"
   ]
  },
