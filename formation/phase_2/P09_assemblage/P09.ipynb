    "### Étape 5 — Vérifier la garde `if __name__ == '__main__'`\n",
    "\n",
    "Simule ce qui se passe quand on importe vs quand on exécute directement."
   ]
  },
  {
   "cell_type": "code",
   "id": "verifier-garde",
   "metadata": {},
   "execution_count": null,
   "outputs": [],
   "source": [
    "# Cellule 5 — Simulation de la garde\n",
    "\n",
    "def simuler_execution_directe():\n",
    "    # Simule : python main.py\n",
    "    nom_module = '__main__'  # valeur quand exécuté directement\n",
    "    if nom_module == '__main__':\n",
    "        print('→ Exécution directe : main() est appelée.')\n",
    "    else:\n",
    "        print('→ Import : main() N\'est PAS appelée.')\n",
    "\n",
    "def simuler_import():\n",
    "    # Simule : import main (depuis un autre fichier)\n",
    "    nom_module = 'main'  # valeur quand importé\n",
    "    if nom_module == '__main__':\n",
    "        print('→ Exécution directe : main() est appelée.')\n",
    "    else:\n",
    "        print('→ Import : main() N\'est PAS appelée.')\n",
    "\n",
    "simuler_execution_directe()\n",
    "simuler_import()\n",
    "\n",
    "# Vérification\n",
    "assert True  # les deux fonctions s'exécutent sans erreur\n",
    "print('Test de la garde réussi.')"
   ]
