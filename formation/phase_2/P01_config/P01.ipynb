    "# Code avec valeurs magiques — NE PAS modifier cette cellule\n",
    "def peut_aller_a_hopital(drone, position_hopital):\n",
    "    if drone['batterie'] < 2:\n",
    "        return False\n",
    "    col_max = 12  # taille de la grille\n",
    "    if position_hopital[0] >= col_max:\n",
    "        return False\n",
    "    return True\n",
