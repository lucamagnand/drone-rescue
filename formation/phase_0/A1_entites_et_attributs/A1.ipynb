    "        batterie_max (int): capacit\u00e9 maximale\n",
    "\n",
    "    Returns:\n",
    "        dict: drone avec tous ses attributs initialis\u00e9s\n",
    "    \"\"\"\n",
    "    # TODO : retourner le dictionnaire avec tous les attributs\n",
    "    return {}  # \u00e0 compl\u00e9ter\n",
    "\n",
    "# V\u00e9rification\n",
    "d = creer_drone('D1', col=0, lig=0, batterie_max=10)\n",
    "assert d['id'] == 'D1', \"id incorrect\"\n",
    "assert d['col'] == 0, \"col incorrect\"\n",
    "assert d['lig'] == 0, \"lig incorrect\"\n",
    "assert d['batterie'] == 10, \"batterie doit \u00eatre \u00e9gale \u00e0 batterie_max \u00e0 la cr\u00e9ation\"\n",
    "assert d['batterie_max'] == 10, \"batterie_max incorrect\"\n",
    "assert d['survivant'] is None, \"survivant doit \u00eatre None au d\u00e9part\"\n",
    "assert d['bloque'] == 0, \"bloque doit \u00eatre 0 au d\u00e9part\"\n",
    "assert d['hors_service'] is False, \"hors_service doit \u00eatre False au d\u00e9part\"\n",
    "print('\u2705 creer_drone() : OK')"
   ]
